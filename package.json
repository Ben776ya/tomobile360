{
  "name": "tomobile360",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "build": "npm run validate-content && cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:moccaz": "npx tsx scripts/test-moccaz.ts",
    "test:audit": "tsx --test scripts/lib/__tests__/validate-route.test.ts scripts/lib/__tests__/extract-internal-links.test.ts scripts/lib/__tests__/audit-articles.test.ts",
    "audit:internal-links": "tsx --env-file=.env.local scripts/audit-internal-links.ts",
    "validate-content": "tsx --env-file-if-exists=.env.local scripts/validate-content.ts",
    "fix:broken-links": "tsx --env-file=.env.local scripts/fix-broken-links.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.4",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "@types/sanitize-html": "^2.16.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "eslint-plugin-security": "^3.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "happy-dom": "^15.11.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "tus-js-client": "^4.3.1",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
